# transcript-intel configuration
# Copy this file to .env and fill in your real values.
# .env is gitignored — it should NEVER be committed.

# Path to the dataset folder (the parent directory containing all 100
# call_<id>/ subdirectories). Update this to wherever you placed the
# interview-assignment/dataset folder on your machine.
DATASET_ROOT=/path/to/interview-assignment/dataset

# LLM configuration (optional — pipeline runs without these)
LLM_BASE_URL=https://api.minimax.io/v1
LLM_MODEL=MiniMax-Text-01
LLM_API_KEY=your-minimax-api-key-here